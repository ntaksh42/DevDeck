        <mxCell id="s4" value="&#9315; Tauri IPC で Rust へ&lt;br&gt;invoke(&quot;search_pull_requests&quot;, 条件)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8ff;strokeColor=#a855f7;fontColor=#581c87;" vertex="1" parent="1">
