        <mxCell id="s1" value="&#9312; 画面で操作&lt;br&gt;例: PR検索の [検索] ボタン&lt;br&gt;src/features/.../PullRequestSearch.tsx" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#3b82f6;fontColor=#1e3a8a;" vertex="1" parent="1">
