          <mxGeometry x="340" y="170" width="360" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s3" value="&#9314; 実行環境を判定&lt;br&gt;isTauriRuntime() ? invoke() : demoInvoke()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8ff;strokeColor=#a855f7;fontColor=#581c87;" vertex="1" parent="1">
          <mxGeometry x="340" y="260" width="360" height="60" as="geometry" />
