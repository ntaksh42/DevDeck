{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevDeck",
  "version": "0.1.40",
  "identifier": "com.azdodeck.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DevDeck",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "publisher": "DevDeck contributors",
    "copyright": "Copyright © 2026 DevDeck contributors",
    "category": "DeveloperTool",
    "shortDescription": "Developer desktop dashboard",
    "longDescription": "DevDeck is a local desktop dashboard for your development platforms. Browse pull requests assigned to you, search work items and commits across projects, and take quick actions — all from a single window backed by a local cache.",
    "homepage": "https://github.com/ntaksh42/DevDeck",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "English"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ntaksh42/DevDeck/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_TAURI_SIGNING_PUBLIC_KEY"
    }
  }
}
