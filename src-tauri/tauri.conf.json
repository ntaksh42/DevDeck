{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AzDoDeck",
  "version": "0.1.11",
  "identifier": "com.azdodeck.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AzDoDeck",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "AzDoDeck contributors",
    "copyright": "Copyright © 2026 AzDoDeck contributors",
    "category": "DeveloperTool",
    "shortDescription": "Azure DevOps desktop dashboard",
    "longDescription": "AzDoDeck is a local desktop dashboard for Azure DevOps. Browse pull requests assigned to you, search work items and commits across projects, and take quick actions — all from a single window backed by a local cache.",
    "homepage": "https://github.com/ntaksh42/azdo-dashboard",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"]
      }
    }
  }
}
